# SDK .gitignore — kept in sync with the rsync exclude list in
# `.cursor/rules/sdk-publish-block.mdc`. This file ships from the
# monorepo to the public mirror via the publish-block rsync so
# the mirror's `git add -A` is safe even if a stray exclude is
# missed at rsync time. See the parent monorepo's root
# `.gitignore` for the broader scope; this is the SDK-only subset
# that a customer cloning the public mirror should never see.

# ─── Python build artefacts ──────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# ─── Virtual envs ────────────────────────────────────────────────
.venv/
venv/
env/

# ─── Local secrets (the mirror is PUBLIC — never let these leak) ─
.env
.env.*

# ─── Tooling caches ──────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ─── IDE / OS litter ─────────────────────────────────────────────
.DS_Store
.idea/
.vscode/

# ─── Logs / runtime artefacts ────────────────────────────────────
*.log
